# Local development example.
# Copy this file to .env.local or .env and replace placeholders with real values.
# Never commit real Neon credentials or API keys.

# Neon pooled connection string.
# Use this for the running application in serverless environments.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB_NAME?sslmode=require"

# Neon direct connection string.
# Use this for Prisma CLI commands and migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB_NAME?sslmode=require"

# Auth.js / NextAuth v5-style variables for the Phase 3 setup.
AUTH_SECRET="replace-with-a-long-random-local-secret"
AUTH_URL="http://localhost:3000"
AUTH_GOOGLE_ID="replace-with-google-oauth-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-oauth-client-secret"

# Legacy aliases are local migration aids only. Phase 3 uses AUTH_* names.
NEXTAUTH_SECRET="replace-with-a-long-random-local-secret"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID="replace-with-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-oauth-client-secret"

GEMINI_API_KEY="replace-with-your-local-dev-key"
GOOGLE_MAPS_API_KEY="replace-with-your-local-dev-key"
GOOGLE_PLACES_API_KEY="replace-with-your-local-dev-key"
GOOGLE_ROUTES_API_KEY="replace-with-your-local-dev-key"
